{
  "manifest_version": 3,
  "name": "AutoQuePrompt for Google Flow",
  "version": "1.5.0",
  "description": "Queue a list of prompts and auto-generate them one-by-one in Google Flow. Paste prompts separated by blank lines, press Start, walk away.",
  "permissions": ["storage", "sidePanel", "scripting", "activeTab", "tabs", "debugger"],
  "host_permissions": [
    "https://labs.google/*",
    "https://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AutoQuePrompt — open queue panel"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/*", "https://gemini.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
